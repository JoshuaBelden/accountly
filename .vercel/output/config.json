{
	"version": 3,
	"routes": [
		{
			"src": ".*",
			"continue": true,
			"transforms": [
				{
					"type": "request.query",
					"op": "delete",
					"target": {
						"key": "__pathname"
					}
				}
			]
		},
		{
			"src": "/accounts",
			"dest": "/accounts/"
		},
		{
			"src": "/accounts/",
			"status": 308,
			"headers": {
				"Location": "/accounts"
			}
		},
		{
			"src": "/bills",
			"dest": "/bills/"
		},
		{
			"src": "/bills/",
			"status": 308,
			"headers": {
				"Location": "/bills"
			}
		},
		{
			"src": "/budget",
			"dest": "/budget/"
		},
		{
			"src": "/budget/",
			"status": 308,
			"headers": {
				"Location": "/budget"
			}
		},
		{
			"src": "/merchants",
			"dest": "/merchants/"
		},
		{
			"src": "/merchants/",
			"status": 308,
			"headers": {
				"Location": "/merchants"
			}
		},
		{
			"src": "/networth",
			"dest": "/networth/"
		},
		{
			"src": "/networth/",
			"status": 308,
			"headers": {
				"Location": "/networth"
			}
		},
		{
			"src": "/planner",
			"dest": "/planner/"
		},
		{
			"src": "/planner/",
			"status": 308,
			"headers": {
				"Location": "/planner"
			}
		},
		{
			"src": "/settings",
			"dest": "/settings/"
		},
		{
			"src": "/settings/",
			"status": 308,
			"headers": {
				"Location": "/settings"
			}
		},
		{
			"src": "/tools",
			"dest": "/tools/"
		},
		{
			"src": "/tools/",
			"status": 308,
			"headers": {
				"Location": "/tools"
			}
		},
		{
			"src": "/tools/loan-payoff",
			"dest": "/tools/loan-payoff/"
		},
		{
			"src": "/tools/loan-payoff/",
			"status": 308,
			"headers": {
				"Location": "/tools/loan-payoff"
			}
		},
		{
			"src": "/tools/subscriptions",
			"dest": "/tools/subscriptions/"
		},
		{
			"src": "/tools/subscriptions/",
			"status": 308,
			"headers": {
				"Location": "/tools/subscriptions"
			}
		},
		{
			"src": "/transactions",
			"dest": "/transactions/"
		},
		{
			"src": "/transactions/",
			"status": 308,
			"headers": {
				"Location": "/transactions"
			}
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/_app/immutable/.+",
			"status": 404,
			"continue": false
		},
		{
			"src": "^/api/sync/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/api/sync/[id]"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {
		"index.html": {
			"path": ""
		},
		"accounts.html": {
			"path": "accounts"
		},
		"bills.html": {
			"path": "bills"
		},
		"budget.html": {
			"path": "budget"
		},
		"merchants.html": {
			"path": "merchants"
		},
		"networth.html": {
			"path": "networth"
		},
		"planner.html": {
			"path": "planner"
		},
		"settings.html": {
			"path": "settings"
		},
		"tools.html": {
			"path": "tools"
		},
		"tools/loan-payoff.html": {
			"path": "tools/loan-payoff"
		},
		"tools/subscriptions.html": {
			"path": "tools/subscriptions"
		},
		"transactions.html": {
			"path": "transactions"
		}
	}
}