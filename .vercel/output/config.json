{
	"version": 3,
	"routes": [
		{
			"src": ".*",
			"continue": true,
			"transforms": [
				{
					"type": "request.query",
					"op": "delete",
					"target": {
						"key": "__pathname"
					}
				}
			]
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/_app/immutable/.+",
			"status": 404,
			"continue": false
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/accounts/?(?:/__data.json)?$",
			"dest": "/accounts"
		},
		{
			"src": "^/api/sync/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/api/sync/[id]"
		},
		{
			"src": "^/bills/?(?:/__data.json)?$",
			"dest": "/bills"
		},
		{
			"src": "^/budget/?(?:/__data.json)?$",
			"dest": "/budget"
		},
		{
			"src": "^/merchants/?(?:/__data.json)?$",
			"dest": "/merchants"
		},
		{
			"src": "^/networth/?(?:/__data.json)?$",
			"dest": "/networth"
		},
		{
			"src": "^/planner/?(?:/__data.json)?$",
			"dest": "/planner"
		},
		{
			"src": "^/settings/?(?:/__data.json)?$",
			"dest": "/settings"
		},
		{
			"src": "^/tools/?(?:/__data.json)?$",
			"dest": "/tools"
		},
		{
			"src": "^/tools/loan-payoff/?(?:/__data.json)?$",
			"dest": "/tools/loan-payoff"
		},
		{
			"src": "^/tools/subscriptions/?(?:/__data.json)?$",
			"dest": "/tools/subscriptions"
		},
		{
			"src": "^/transactions/?(?:/__data.json)?$",
			"dest": "/transactions"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}